# Reelio configuration
# Preferred location: ~/.reelio/.env (created by `reelio setup`)
# Repo-local .env is supported for development only.

# Instagram credentials (used only for first-time login)
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Browser mode: true = no window, false = show browser (use false for first login)
HEADLESS=true

# Playwright session profile (default: ~/.reelio/session)
# SESSION_DIR=~/.reelio/session

# API server port
PORT=3001

# Reels per page
REELS_PER_PAGE=12

# Buffer management
REEL_BUFFER_MIN=12
REEL_PREFETCH_THRESHOLD=3
REEL_STARTUP_SEED=12

# API URL used by Claude hooks (default: http://localhost:3001)
REELIO_API=http://localhost:3001

# User data directory (default: ~/.reelio)
# REELIO_HOME=~/.reelio
